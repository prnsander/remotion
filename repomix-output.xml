                    backgroundColor: c,
                  }}
                />
              ))}
            </div>
            <div
              style={{
                position: "absolute",
                left: "50%",
                transform: "translateX(-50%)",
                width: 460,
                height: 26,
                backgroundColor: "rgba(255,255,255,0.04)",

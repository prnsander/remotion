          {/* Accent line */}
          <div
            style={{
              width: lineWidth,
              height: 4,
              backgroundColor: "#6366F1",
              borderRadius: 2,
              margin: "20px auto 0",
            }}
          />
        </div>

        {/* Tagline */}
        <div
          style={{
            opacity: taglineOpacity,
            transform: `translateY(${taglineY}px)`,
            marginTop: 32,
            fontFamily,
            fontSize: 28,

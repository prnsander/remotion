                alignItems: "center",
                justifyContent: "center",
              }}
            >
              <span
                style={{
                  fontFamily: MONO,
                  fontSize: 13,
                  color: "rgba(255,255,255,0.32)",
                }}
              >
                app.localesy.com
              </span>
            </div>
          </div>

          {/* Dashboard interior */}
          <div
            style={{ height: 540, backgroundColor: "#07060c", display: "flex" }}
          >
            {/* Sidebar */}
            <div
              style={{
                width: 196,

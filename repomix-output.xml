              fontFamily: FONT,
              fontSize: 48,
              fontWeight: 800,
              letterSpacing: "-2px",
              color: "#ffffff",
              lineHeight: 1.05,
              opacity: headOpacity,
              transform: `translateX(${headX}px)`,
              marginBottom: 12,
            }}
          >
            The smart localization platform.
          </div>
          <div
            style={{
              fontFamily: FONT,
              fontSize: 17,
              color: "rgba(255,255,255,0.55)",
              lineHeight: 1.5,
              maxWidth: 520,
              opacity: subOpacity,
            }}
          >
          </div>
        </div>

        {/* Browser mockup — now in normal flow below the text */}
        <div
          style={{
            width: 1440,
            borderRadius: "14px",
            overflow: "hidden",
            transform: `translateY(${mockY}px)`,
            opacity: interpolate(frame, [38, 56], [0, 1], {
              extrapolateLeft: "clamp",
              extrapolateRight: "clamp",
            }),
            boxShadow:
              "0 0 0 1px rgba(255,255,255,0.07), 0 60px 120px rgba(0,0,0,0.95), 0 0 0 1px rgba(144,90,246,0.04), 0 0 180px rgba(144,90,246,0.06)",
          }}

                <span
                  style={{
                    backgroundColor: "rgba(144,90,246,0.12)",
                    border: "1px solid rgba(144,90,246,0.22)",
                    borderRadius: "8px",
                    padding: "6px 14px",
                    fontFamily: FONT,
                    fontSize: 13,
                    color: C.accent,
                    fontWeight: 600,
                  }}
                >
                  + New
                </span>
              </div>

              {/* Project rows */}
              {PROJECTS.map((p, i) => {
                const startF = 62 + i * 18;
                const rowOpacity = interpolate(
                  frame,
                  [startF, startF + 14],
                  [0, 1],
                  { extrapolateLeft: "clamp", extrapolateRight: "clamp" }
                );
                const fillPct = interpolate(
                  frame,
                  [startF, startF + 40],
                  [0, p.pct],
                  { extrapolateLeft: "clamp", extrapolateRight: "clamp" }
                );
                return (
                  <div
                    key={p.name}
                    style={{
                      height: 58,
                      backgroundColor: "rgba(255,255,255,0.02)",
                      borderRadius: "10px",
                      border: "1px solid rgba(255,255,255,0.05)",
                      margin: "4px 0",
                      padding: "0 20px",
                      display: "flex",
                      alignItems: "center",
                      justifyContent: "space-between",
                      opacity: rowOpacity,
                    }}
                  >
                    <div>
                      <div
                        style={{
                          fontFamily: FONT,
                          fontSize: 15,
                          fontWeight: 600,
                          color: "#fff",
                        }}
                      >
                        {p.name}
                      </div>
                      <div style={{ fontSize: 18, marginTop: 2 }}>
                        {p.flags}
                      </div>
                    </div>
                    <div
                      style={{
                        height: 5,
                        width: 200,
                        backgroundColor: "rgba(255,255,255,0.06)",
                        borderRadius: "3px",
                      }}
